# App
APP_ENV=dev
DEBUG=true

# API
API_V1_PREFIX=/api/v1

# Database (used by docker-compose; override for local)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=gamification
POSTGRES_PASSWORD=gamification_dev
POSTGRES_DB=gamification_core

# SQLAlchemy (constructed from above or set directly)
DATABASE_URL=postgresql+asyncpg://gamification:gamification_dev@postgres:5432/gamification_core

# Redis (optional)
REDIS_URL=redis://redis:6379/0
